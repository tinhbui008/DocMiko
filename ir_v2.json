                227.87957763671875,
                526.9469604492188,
                239.66958618164062
              ],
              "spans": [
                {
                  "text": "revenues are secured. “Governmental Operations” includes costs associated with continuing, expanding or ",
                  "bbox": [
                    57.2400016784668,
                    227.87957763671875,
                    526.9469604492188,
                    239.66958618164062
                  ],
                  "font": "ProximaNova-Regular",
                  "size": 10.0,
