                530.0798950195312,
                253.66958618164062
              ],
              "spans": [
                {
                  "text": "modifying local governmental operations to meet disaster-related needs and includes costs such as, but not ",
                  "bbox": [
                    57.2400016784668,
                    241.87957763671875,
                    530.0798950195312,
                    253.66958618164062
                  ],
