                498.9599304199219,
                211.66958618164062
              ],
              "spans": [
                {
                  "text": "More than $40 million is available to fund governmental operations within these Florida counties and ",
                  "bbox": [
                    57.2400016784668,
                    199.87957763671875,
                    498.9599304199219,
                    211.66958618164062
                  ],
                  "font": "ProximaNova-Regular",
