                214.12957763671875,
                528.5677490234375,
                225.91958618164062
              ],
              "spans": [
                {
                  "text": "Loans are available up to $50,000 per eligible applicant and loans made under this program are short-term, ",
                  "bbox": [
                    57.040000915527344,
                    214.12957763671875,
                    528.5677490234375,
                    225.91958618164062
                  ],
                  "font": "ProximaNova-Regular",
                  "size": 10.0,
                  "color": 4342594,
