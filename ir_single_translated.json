                242.12957763671875,
                546.4788818359375,
                253.91958618164062
              ],
              "spans": [
                {
                  "text": "Emergency Bridge Loans require repayment by the approved applicant. Owners may utilize funding from longer ",
                  "bbox": [
                    57.040000915527344,
                    242.12957763671875,
                    546.4788818359375,
                    253.91958618164062
                  ],
                  "font": "ProximaNova-Regular",
                  "size": 10.0,
                  "color": 4342594,
                  "flags": 4,
