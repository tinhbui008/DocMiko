                547.8079223632812,
                267.9195861816406
              ],
              "spans": [
                {
                  "text": "term financial resources, such as U.S. Small Business Administration economic injury disaster loans, to repay the ",
                  "bbox": [
                    57.040000915527344,
                    256.12957763671875,
                    547.8079223632812,
                    267.9195861816406
                  ],
