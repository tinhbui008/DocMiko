                228.12957763671875,
                529.3778076171875,
                239.91958618164062
              ],
              "spans": [
                {
                  "text": "personal loans using State of Florida funds – they are not grants and must be repaid. Florida Small Business ",
                  "bbox": [
                    57.040000915527344,
                    228.12957763671875,
                    529.3778076171875,
                    239.91958618164062
                  ],
                  "font": "ProximaNova-Regular",
