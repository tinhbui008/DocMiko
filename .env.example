# ============================================================
# Copy this file to .env ON THE SERVER and fill in real values.
# .env itself is gitignored (never committed).
#   cp .env.example .env  &&  nano .env
# ============================================================

# LLM provider: "anthropic" (Claude native) or "openai_compatible"
LLM_PROVIDER=anthropic

# REQUIRED — your Claude API key
LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# API endpoint (default Anthropic)
LLM_BASE_URL=https://api.anthropic.com

# REQUIRED — model id used for translation
LLM_MODEL=claude-3-5-sonnet-latest

# Generation params
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.2
LLM_SEND_TEMPERATURE=0

# Optional
# ANTHROPIC_VERSION=2023-06-01
