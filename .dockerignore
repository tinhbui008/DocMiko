!ocr_report_dummy.pdf
.translation_cache.jsonl
ocr_debug_*/
extracted_images/
extracted_fonts/
ocr_report_crops/
pdf_test_result/
*_report.json

# OS / IDE
.vscode
.idea
.DS_Store
Thumbs.db
